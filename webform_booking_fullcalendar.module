<?php

/**
 * Implements hook_preprocess_views_view().
 */
function webform_booking_fullcalendar_preprocess_views_view(&$variables) {
  $view = $variables['view'];
  
  if ($view->id() === 'booking_admin_calendar' && empty($view->preview)) {
    $config = \Drupal::config('webform_booking_fullcalendar.settings');
    $target_webform_id = $config->get('webform_id') ?: 'booking';
    $slot_duration = $config->get('slot_duration') ?: 60; // Fetch the duration

    $events = [];
    
    foreach ($view->result as $row) {
      $submission = $row->_entity ?? NULL;
      
      if ($submission && $submission->getEntityTypeId() === 'webform_submission') {
        $data = $submission->getData();
        $element_key = 'booking'; 
        
        if (!empty($data[$element_key])) {
          $booking_parts = explode('|', $data[$element_key]);
          $raw_datetime = $booking_parts[0]; 
          $formatted_datetime = str_replace(' ', 'T', $raw_datetime);
          $client_name = !empty($data['name']) ? $data['name'] : 'Booking ' . $submission->id();

          $events[] = [
            'title' => $client_name,
            'start' => $formatted_datetime, 
            'url' => $submission->toUrl('canonical')->toString(),
          ];
        }
      }
    }

    $variables['#attached']['library'][] = 'webform_booking_fullcalendar/calendar-display';
    $variables['#attached']['drupalSettings']['webform_bookings'] = $events;
    
    // Pass both settings to JS
    $variables['#attached']['drupalSettings']['webform_booking_fullcalendar'] = [
      'webform_id' => $target_webform_id,
      'slot_duration' => $slot_duration,
    ];
    
    $variables['rows'] = [
      '#markup' => '<div id="booking-calendar"></div>',
    ];
  }
}

/**
 * Implements hook_preprocess_webform().
 */
function webform_booking_fullcalendar_preprocess_webform(&$variables) {
  $config = \Drupal::config('webform_booking_fullcalendar.settings');
  $target_webform_id = $config->get('webform_id') ?: 'booking';

  // 3. Only attach the autofill script to the dynamically configured webform
  if ($variables['element']['#webform_id'] === $target_webform_id) {
    $variables['#attached']['library'][] = 'webform_booking_fullcalendar/form-autofill';
  }
}